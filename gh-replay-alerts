#!/usr/bin/env bash
set -euo pipefail

# gh-replay-alerts — GitHub CLI extension
# Replays code scanning alert statuses from a CSV export onto current alerts.
#
# Usage:
#   gh replay-alerts list owner/repo --scope repo > alerts.csv
#   cat alerts.csv | gh replay-alerts owner/repo --scope repo
#   gh replay-alerts my-org --scope org < alerts.csv

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Auto-inject token from gh auth if not already set
export GITHUB_TOKEN="${GITHUB_TOKEN:-$(gh auth token 2>/dev/null || true)}"

if [[ -z "${GITHUB_TOKEN}" ]]; then
    echo "Error: No GITHUB_TOKEN found. Run 'gh auth login' first." >&2
    exit 1
fi

# Route subcommands
case "${1:-}" in
    list)
        shift
        GH_PROG_NAME="gh replay-alerts list" exec python3 "${SCRIPT_DIR}/list_code_scanning_alerts.py" "$@"
        ;;
    ""|help|--help|-h)
        echo "gh replay-alerts — Replay code scanning alert statuses"
        echo ""
        echo "Usage:"
        echo "  gh replay-alerts list <name> [options]     Export alerts as CSV/JSON"
        echo "  gh replay-alerts <name> [options] < csv    Replay states from CSV"
        echo ""
        echo "Options:"
        echo "  --scope repo|org|ent    Scope (default: org)"
        echo "  --state open|resolved   Filter by state"
        echo "  --since DATE|Nd         Only alerts after date (e.g. 2024-10-08, 7d)"
        echo "  --hostname HOST         GHES hostname (default: github.com)"
        echo "  --json                  Output JSON (list only)"
        echo "  --debug                 Enable debug logging"
        echo ""
        echo "Examples:"
        echo "  gh replay-alerts list owner/repo --scope repo > alerts.csv"
        echo "  cat alerts.csv | gh replay-alerts owner/repo --scope repo"
        echo "  gh replay-alerts list my-org --since 7d --json"
        echo "  cat alerts.csv | gh replay-alerts owner/repo --scope repo --debug"
        exit 0
        ;;
    *)
        GH_PROG_NAME="gh replay-alerts" exec python3 "${SCRIPT_DIR}/replay_code_scanning_alert_status.py" "$@"
        ;;
esac
